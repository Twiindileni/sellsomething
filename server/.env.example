SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-publishable-key
# Optional but recommended for admin order management (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=
PORT=5000
# Firebase service account JSON (one line) — enables mobile push notifications
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Resend (re-engagement emails) — set in Vercel env for production
RESEND_API_KEY=
RESEND_FROM_EMAIL="Sell Something <admin@sellsomething.online>"
RESEND_REPLY_TO=admin@sellsomething.online
# Admin inbox for verification ID + social links (comma-separated OK)
VERIFICATION_ADMIN_EMAIL=admin@sellsomething.online
SITE_URL=https://www.sellsomething.online
# Random secret for Vercel cron + manual triggers (Authorization: Bearer <secret>)
CRON_SECRET=
