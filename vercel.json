{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/build",
  "crons": [
    {
      "path": "/api/cron/reengagement",
      "schedule": "0 7 1 * *"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/api/(.*)", "dest": "/api" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
