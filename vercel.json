{
  "version": 2,
  "buildCommand": "npm run build --prefix client",
  "outputDirectory": "client/build",
  "functions": {
    "api/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}

